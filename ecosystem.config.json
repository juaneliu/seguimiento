{
  "apps": [{
    "name": "tablero-estadistico",
    "script": "npm",
    "args": "start",
    "instances": 1,
    "exec_mode": "fork",
    "env": {
      "NODE_ENV": "production",
      "PORT": 3000
    },
    "env_production": {
      "NODE_ENV": "production",
      "PORT": 3000,
      "NEXTAUTH_URL": "https://seguimiento.saem.gob.mx",
      "NEXTAUTH_SECRET": "super_secure_secret_for_production_2025_tablero_estadistico",
      "DATABASE_URL": "postgresql://tablero_user:tablero_secure_pass_2025@localhost:5432/tablero_estadistico?schema=public"
    },
    "log_date_format": "YYYY-MM-DD HH:mm Z",
    "error_file": "/var/log/pm2/tablero-error.log",
    "out_file": "/var/log/pm2/tablero-out.log",
    "time": true,
    "autorestart": true,
    "watch": false,
    "max_memory_restart": "1G"
  }]
}
